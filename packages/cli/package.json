{
  "name": "@manual-code-coverage/cli",
  "version": "0.3.0",
  "description": "CLI for manual-code-coverage: mcc report and mcc verify-pr commands",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "mcc": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node ./dist/bin.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@manual-code-coverage/core": "workspace:*",
    "@octokit/rest": "^21.1.1",
    "commander": "^12.1.0",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-lib-source-maps": "^5.0.6",
    "istanbul-reports": "^3.1.7",
    "istanbul-lib-coverage": "^3.2.2"
  },
  "devDependencies": {
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/node": "^22.0.0",
    "@types/istanbul-lib-coverage": "^2.0.6"
  }
}
